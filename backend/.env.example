# ── Copy to .env and fill in your keys ────────────────────────────────────────
# You only need ONE AI provider key — the backend tries them in order.

# PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/sql_builder

# AI providers — set whichever you have (all are optional individually)
GEMINI_API_KEY=        # Google AI Studio: aistudio.google.com
GROQ_API_KEY=          # Groq console: console.groq.com/keys
COHERE_API_KEY=        # Cohere dashboard: dashboard.cohere.com/api-keys
MISTRAL_API_KEY=       # Mistral console: console.mistral.ai/api-keys
OPENROUTER_API_KEY=    # OpenRouter: openrouter.ai/settings/keys
OPENAI_API_KEY=        # OpenAI (optional): platform.openai.com/api-keys

# Query safety
QUERY_TIMEOUT_SECONDS=10
MAX_RESULT_ROWS=500
